# API server (Express). Vite dev proxy uses the same port — keep in sync with vite.config.js.
# If you see EADDRINUSE on 3001, another Node process is still running; `npm run dev` tries to free 3001 first,
# or stop the old process manually, or set API_PORT to another port (e.g. 3002) here and restart.
API_PORT=3001

# MongoDB — required for API. Examples:
# MONGODB_URI=mongodb://127.0.0.1:27017
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=case_study_crm

# Required in production: JWT signing secret for auth tokens.
JWT_SECRET=

# Optional bootstrap admin account (created on server startup if not existing).
# This email is reserved — sign in as admin; it cannot be used for self-service "Register".
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Optional: max upload size in bytes for POST /api/upload (default 12MB)
# UPLOAD_MAX_BYTES=12582912

# Optional: browser → API base URL (no trailing slash). Use when the Vite build is deployed
# on a different origin than the API. Leave unset in local dev (`npm run dev` uses Vite proxy).
# VITE_API_URL=https://api.example.com

# Optional: import path in downloaded .js for ReferenceCaseStudyForm (see server/lib/generateComponent.js)
# GENERATED_IMPORT_PATH=../../components/reference/ReferenceCaseStudyForm
